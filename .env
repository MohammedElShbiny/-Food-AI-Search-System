DATABASE_TYPE=sqlite
SQLITE_PATH=foods.db
HOST=0.0.0.0
PORT=8000

# AI Provider API Keys (fill in the ones you want to use)
OPENAI_API_KEY=
GEMINI_API_KEY=AIzaSyAh43tZDs_BWLC-ACWyZhP6QdIk39kVEmE
CLAUDE_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
NVIDIA_API_KEY=

# Priority order for AI providers (comma-separated)
AI_PROVIDER_PRIORITY=openai,gemini,claude,openrouter,deepseek,nvidia

# Scraper settings
SCRAPER_TIMEOUT=30
BACKGROUND_SCRAPER_ENABLED=false
BACKGROUND_SCRAPER_BATCH_SIZE=10
BACKGROUND_SCRAPER_INTERVAL=300

# Cache settings
CACHE_TTL=3600
CACHE_MAX_MEMORY=1000

# Node mode: standalone | coordinator | worker
NODE_MODE=standalone
COORDINATOR_URL=
WORKER_NAME=worker-1
WORKER_NGROK_URL=

# Health check settings
HEALTH_CHECK_INTERVAL=15
HEALTH_CHECK_TIMEOUT=5
HEALTH_CHECK_FAILURE_THRESHOLD=3
WORKER_HEARTBEAT_INTERVAL=30
